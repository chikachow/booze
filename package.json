{
  "name": "@chikachow/booze",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "node --run format:check && node --run lint && node --run typecheck && node --run test",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware --report-unused-disable-directives .",
    "lint:fix": "oxlint --type-aware --fix .",
    "test": "pnpm --recursive --if-present test",
    "typecheck": "pnpm --recursive --if-present typecheck"
  },
  "devDependencies": {
    "@tsconfig/node24": "24.0.4",
    "@tsconfig/recommended": "1.0.13",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.12.2",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "oxlint-tsgolint": "0.23.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": "24"
  },
  "packageManager": "pnpm@10.33.4"
}
